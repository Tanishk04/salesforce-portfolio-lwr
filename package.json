{
  "name": "portfolio-lwr",
  "version": "0.0.1",
  "description": "Personal portfolio — Lightning Web Runtime + LWC (OSS)",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf node_modules __lwr_cache__ site",
    "dev": "lwr dev",
    "dev:compat": "lwr dev --mode compat",
    "build": "lwr build --clean",
    "postbuild": "node scripts/fix-redirects.mjs",
    "build:prod-compat": "lwr build --clean --mode prod-compat",
    "start": "lwr start",
    "stage": "npm run build && npm run start",
    "stage:prod-compat": "npm run build:prod-compat && npm run start",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "dependencies": {
    "@lwc/engine-dom": "^9.1.1",
    "@lwrjs/core": "^0.22.12",
    "lwc": "8.22.6",
    "lwr": "^0.22.12"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "rimraf": "^6.0.1",
    "wrangler": "^4.103.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
